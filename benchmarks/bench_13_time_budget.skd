fn measure_step(Duration work_budget) returns Duration {
    new Time started_at = now()
    sleep(work_budget)
    return elapsed(started_at)
}

new Duration target_budget = 5ms
Task(Duration) measurement_task = run measure_step(target_budget)
new Duration measured = wait measurement_task
new Bool respected_lower_bound = measured >= target_budget
new Bool stayed_reasonable = measured < 1s

output("time budget respected")
output(respected_lower_bound and stayed_reasonable)
