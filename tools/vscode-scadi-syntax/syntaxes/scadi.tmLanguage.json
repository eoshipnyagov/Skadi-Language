{
  "scopeName": "source.scadi",
  "name": "Scadi",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#function-declaration" },
    { "include": "#type-declaration" },
    { "include": "#control-keywords" },
    { "include": "#modifiers" },
    { "include": "#builtins" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#member-call" },
    { "include": "#member-access" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.scadi", "match": "//.*$" },
        { "name": "comment.block.scadi", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.scadi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.scadi", "match": "\\\\." },
            { "name": "variable.interpolation.scadi", "match": "__[A-Za-z_][A-Za-z0-9_]*__" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.scadi", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.integer.scadi", "match": "\\b\\d+\\b" }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "name": "meta.function.declaration.scadi",
          "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.scadi" },
            "2": { "name": "entity.name.function.scadi" }
          }
        }
      ]
    },
    "type-declaration": {
      "patterns": [
        {
          "name": "meta.type.declaration.struct.scadi",
          "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.scadi" },
            "2": { "name": "entity.name.type.scadi" }
          }
        },
        {
          "name": "meta.type.declaration.label.scadi",
          "match": "\\b(label)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.scadi" },
            "2": { "name": "entity.name.type.scadi" }
          }
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.scadi",
          "match": "\\b(if|else|when|is|while|for|in|iterate|as|loop|return|on|event|interrupt|error|run|wait)\\b"
        }
      ]
    },
    "modifiers": {
      "patterns": [
        {
          "name": "storage.modifier.scadi",
          "match": "\\b(danger|new|fixed|const|hide|local|allow|drop|direct|my)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.scadi",
          "match": "\\b(Int|Float|Byte|bool|char|Text|String|Path|i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|Vec2|Vec3|Vec4|Link|List)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.scadi",
          "match": "\\b(true|false|null|PI|E)\\b"
        },
        {
          "name": "constant.other.error-code.scadi",
          "match": "\\b[A-Z][A-Z0-9_]*\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.scadi",
          "match": "\\b(output|print|input|read|write|len|find|slice|concat|args|delay|sleep)\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.builtin.fs.scadi",
          "match": "\\bfs\\.(list|read|write|is_dir|join)\\b"
        }
      ]
    },
    "member-call": {
      "patterns": [
        {
          "name": "meta.member.call.scadi",
          "match": "\\.\\s*(push|pop|send|receive|signal|toggle)\\b(?=\\s*\\()",
          "captures": {
            "1": { "name": "support.function.method.scadi" }
          }
        }
      ]
    },
    "member-access": {
      "patterns": [
        {
          "name": "variable.other.member.scadi",
          "match": "\\.\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.property.scadi" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.scadi",
          "match": "\\b(and|or|not|xor|div|mod)\\b|==|!=|<=|>=|\\+\\=|\\-\\=|\\*\\=|\\/\\=|\\+\\+|\\-\\-|=|<|>|\\+|\\-|\\*|\\/|\\^"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.scadi",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    }
  }
}
