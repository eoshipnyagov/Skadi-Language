{
  "name": "skadi-syntax",
  "displayName": "Skadi Syntax",
  "description": "Syntax highlighting for Skadi language",
  "version": "0.1.0",
  "publisher": "skadi-local",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.85.0"
  },
  "files": [
    "LICENSE",
    "language-configuration.json",
    "package.json",
    "README.md",
    "syntaxes/**"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "skadi",
        "aliases": ["Skadi", "skadi"],
        "extensions": [".skd"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "skadi",
        "scopeName": "source.skadi",
        "path": "./syntaxes/skadi.tmLanguage.json"
      }
    ]
  }
}


