{
  "scopeName": "source.skadi",
  "name": "Skadi",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#memory-size-literals" },
    { "include": "#numbers" },
    { "include": "#typed-declarations" },
    { "include": "#function-signature" },
    { "include": "#function-declaration" },
    { "include": "#type-declaration" },
    { "include": "#label-members" },
    { "include": "#struct-field-declarations" },
    { "include": "#struct-literal-fields" },
    { "include": "#paired-keywords" },
    { "include": "#iterate-alias" },
    { "include": "#control-keywords" },
    { "include": "#modifiers" },
    { "include": "#memory-surface" },
    { "include": "#self-keyword" },
    { "include": "#builtins" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#member-call" },
    { "include": "#member-access" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.skd", "match": "//.*$" },
        { "name": "comment.block.skd", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.skd",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.skd", "match": "\\\\." },
            { "name": "variable.interpolation.skd", "match": "__[A-Za-z_][A-Za-z0-9_]*__" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.skd", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.integer.skd", "match": "\\b\\d+\\b" }
      ]
    },
    "memory-size-literals": {
      "patterns": [
        {
          "name": "constant.numeric.memory-size.skd",
          "match": "\\b\\d+(?:b|kb|mb|gb)\\b"
        }
      ]
    },
    "function-signature": {
      "patterns": [
        {
          "name": "meta.function.signature.danger.skd",
          "begin": "\\b(danger)\\s+(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "storage.modifier.skd" },
            "2": { "name": "storage.type.function.skd" },
            "3": { "name": "entity.name.function.skd" },
            "4": { "name": "punctuation.section.parameters.begin.skd" }
          },
          "end": "(\\))(?=\\s*(?:[A-Za-z_][A-Za-z0-9_]*\\s*(?:List)?\\s*)?\\{)",
          "endCaptures": {
            "1": { "name": "punctuation.section.parameters.end.skd" }
          },
          "patterns": [
            { "include": "#types" },
            {
              "name": "variable.parameter.skd",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?:,|\\)))"
            },
            {
              "name": "punctuation.separator.parameter.skd",
              "match": ","
            }
          ]
        },
        {
          "name": "meta.function.signature.skd",
          "begin": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "storage.type.function.skd" },
            "2": { "name": "entity.name.function.skd" },
            "3": { "name": "punctuation.section.parameters.begin.skd" }
          },
          "end": "(\\))(?=\\s*(?:[A-Za-z_][A-Za-z0-9_]*\\s*(?:List)?\\s*)?\\{)",
          "endCaptures": {
            "1": { "name": "punctuation.section.parameters.end.skd" }
          },
          "patterns": [
            { "include": "#types" },
            {
              "name": "variable.parameter.skd",
              "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*(?:,|\\)))"
            },
            {
              "name": "punctuation.separator.parameter.skd",
              "match": ","
            }
          ]
        }
      ]
    },
    "typed-declarations": {
      "patterns": [
        {
          "name": "meta.variable.declaration.skd",
          "match": "\\b(new|const|fixed)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(List))?\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.modifier.skd" },
            "2": { "name": "storage.type.skd" },
            "3": { "name": "storage.type.skd" },
            "4": { "name": "variable.other.definition.skd" }
          }
        }
      ]
    },
    "function-declaration": {
      "patterns": [
        {
          "name": "meta.function.declaration.skd",
          "match": "\\b(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.skd" },
            "2": { "name": "entity.name.function.skd" }
          }
        }
      ]
    },
    "label-members": {
      "patterns": [
        {
          "name": "constant.other.error-code.member.skd",
          "match": "^\\s*([A-Z][A-Za-z0-9_]*)\\b\\s*$",
          "captures": {
            "1": { "name": "constant.other.error-code.skd" }
          }
        }
      ]
    },
    "struct-field-declarations": {
      "patterns": [
        {
          "name": "meta.struct.field.declaration.skd",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(List))?\\s+([A-Za-z_][A-Za-z0-9_]*)\\b\\s*$",
          "captures": {
            "1": { "name": "storage.type.skd" },
            "2": { "name": "storage.type.skd" },
            "3": { "name": "variable.other.property.declaration.skd" }
          }
        }
      ]
    },
    "type-declaration": {
      "patterns": [
        {
          "name": "meta.type.declaration.struct.skd",
          "match": "\\b(struct)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.skd" },
            "2": { "name": "entity.name.type.skd" }
          }
        },
        {
          "name": "meta.type.declaration.label.skd",
          "match": "\\b(label)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.skd" },
            "2": { "name": "entity.name.type.skd" }
          }
        }
      ]
    },
    "struct-literal-fields": {
      "patterns": [
        {
          "name": "variable.other.property.struct-literal.skd",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*=)"
        }
      ]
    },
    "paired-keywords": {
      "patterns": [
        {
          "name": "meta.control.on-error.skd",
          "match": "\\b(on)\\s+(error)\\b",
          "captures": {
            "1": { "name": "keyword.control.exception.skd" },
            "2": { "name": "keyword.control.exception.skd" }
          }
        },
        {
          "name": "meta.control.place-in.skd",
          "match": "\\b(place)\\s+(in)\\b",
          "captures": {
            "1": { "name": "keyword.control.resource.skd" },
            "2": { "name": "keyword.control.resource.skd" }
          }
        }
      ]
    },
    "iterate-alias": {
      "patterns": [
        {
          "name": "meta.iterate.alias.skd",
          "match": "\\b(iterate)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(as)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.control.skd" },
            "2": { "name": "variable.other.readwrite.skd" },
            "3": { "name": "keyword.control.skd" },
            "4": { "name": "variable.other.definition.skd" }
          }
        }
      ]
    },
    "control-keywords": {
      "patterns": [
        {
          "name": "keyword.control.skd",
          "match": "\\b(if|else|when|is|while|for|in|iterate|as|loop|return|returns|break|continue|pass|on|event|interrupt|error|run|wait|place)\\b"
        }
      ]
    },
    "modifiers": {
      "patterns": [
        {
          "name": "storage.modifier.skd",
          "match": "\\b(danger|new|fixed|const|hide|local|allow|drop|direct)\\b"
        }
      ]
    },
    "memory-surface": {
      "patterns": [
        {
          "name": "storage.type.resource.memory.skd",
          "match": "\\bMemory\\b"
        },
        {
          "name": "support.function.memory.allocator.skd",
          "match": "\\bmemory\\b(?=\\s*\\()"
        },
        {
          "name": "support.function.memory.lifecycle.skd",
          "match": "\\bclear\\b(?=\\s*\\()"
        }
      ]
    },
    "self-keyword": {
      "patterns": [
        {
          "name": "variable.language.self.skd",
          "match": "\\bmy\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.skd",
          "match": "\\b(Int|Float|Bool|Char|Byte|bool|char|Text|String|Path|Time|Memory|i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|Vec2|Vec3|Vec4|Link|List|Canvas|Window|Point|Size)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.skd",
          "match": "\\b(true|false|null|PI|TAU|E|EPSILON)\\b"
        },
        {
          "name": "constant.other.error-code.skd",
          "match": "\\b[A-Z][A-Z0-9_]*\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.skd",
          "match": "\\b(output|print|input|read|write|len|contains|find|slice|concat|args|delay|sleep|abs|min|max|clamp|floor|ceil|round|sin|cos|atan2|sqrt|root|deg_to_rad|rad_to_deg)\\b(?=\\s*\\()"
        },
        {
          "name": "meta.namespace.fs.skd",
          "match": "\\b(fs)\\.(list|read|write|is_dir|join)\\b",
          "captures": {
            "1": { "name": "entity.name.namespace.skd" },
            "2": { "name": "support.function.builtin.fs.skd" }
          }
        }
      ]
    },
    "member-call": {
      "patterns": [
        {
          "name": "meta.member.call.memory.skd",
          "match": "\\.\\s*(clear)\\b(?=\\s*\\()",
          "captures": {
            "1": { "name": "support.function.memory.lifecycle.skd" }
          }
        },
        {
          "name": "meta.member.call.skd",
          "match": "\\.\\s*([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*\\()",
          "captures": {
            "1": { "name": "support.function.method.skd" }
          }
        }
      ]
    },
    "member-access": {
      "patterns": [
        {
          "name": "variable.other.member.skd",
          "match": "\\.\\s*([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.property.skd" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.skd",
          "match": "\\b(and|or|not|xor|div|mod)\\b|==|!=|<=|>=|\\+\\=|\\-\\=|\\*\\=|\\/\\=|\\+\\+|\\-\\-|=|<|>|\\+|\\-|\\*|\\/|\\^"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.skd",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()"
        }
      ]
    }
  }
}


